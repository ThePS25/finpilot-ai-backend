NODE_ENV=development
PORT=5000

# MongoDB (required)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/finpilot?retryWrites=true&w=majority

# JWT (required — use long random strings; min 32 chars in production)
JWT_ACCESS_SECRET=your-access-token-secret-min-32-chars
JWT_REFRESH_SECRET=your-refresh-token-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Cookies
# Production (Vercel frontend + Render API): COOKIE_SECURE=true (enables SameSite=None)
# Local HTTP: COOKIE_SECURE=false
COOKIE_SECURE=false
# Leave COOKIE_DOMAIN unset for cross-site deploys. Only set for a shared apex domain.
# COOKIE_DOMAIN=.yourdomain.com

# Frontend origin for CORS + email links (no trailing slash)
# Required in production
CLIENT_URL=http://localhost:5173
# Optional extra origins (comma-separated), e.g. Vercel preview URLs
# CLIENT_URLS=https://finpilot-git-main.vercel.app

# Cloudinary (payslips)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Gemini AI
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# Email (required in production for password reset + email verification)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=FinPilot AI <noreply@finpilot.ai>
